# Database Configuration
# Copy this file to .env and set your values

# MongoDB Port (defaults to 27017 if not set)
MONGO_PORT=27777

# MongoDB Root User Credentials (REQUIRED)
MONGO_ROOT_USERNAME=your_username
MONGO_ROOT_PASSWORD=your_secure_password

# MongoDB Database Name (defaults to gerifinancial if not set)
MONGO_DATABASE=gerifinancial

# Redis Configuration for Queue System
# Redis Port (defaults to 6379 if not set)
REDIS_PORT=6379

# Redis Password (leave empty for no password)
REDIS_PASSWORD=

# Redis Host (defaults to localhost for development)
REDIS_HOST=localhost

# Redis Database Number (defaults to 0 if not set)
REDIS_DB=0
